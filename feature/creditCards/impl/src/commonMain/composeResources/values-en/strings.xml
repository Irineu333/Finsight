    <string name="delete_credit_card_title">Delete Card</string>
    <string name="delete_credit_card_message">Are you sure you want to delete the card \"%1$s\"? Associated invoices and transactions will also be deleted.</string>
    <string name="delete_credit_card_confirm">Delete</string>

    <!-- Delete Future Invoice Modal -->
    <string name="delete_future_invoice_title">Delete Invoice</string>
