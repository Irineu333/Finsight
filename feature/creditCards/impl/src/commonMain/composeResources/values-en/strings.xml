    <string name="close_invoice_date_label">Closing Date</string>
    <string name="close_invoice_confirm">Close Invoice</string>

    <!-- Reopen Invoice Modal -->
    <string name="reopen_invoice_title">Reopen Invoice</string>
    <string name="reopen_invoice_confirm_message">Are you sure you want to reopen this invoice?</string>
    <string name="reopen_invoice_description">The invoice will return to \"Open\" status and you can add new transactions.</string>
    <string name="reopen_invoice_cancel">Cancel</string>
    <string name="reopen_invoice_confirm">Reopen</string>
